{
  "name": "secret-hitler-passandplay",
  "version": "1.0.0",
  "private": true,
  "description": "Offline, single-device pass-and-play adaptation of Secret Hitler (Expo + WebView). Configurable rules, Communist/XL variant, and AI bots. Unofficial fan project, CC BY-NC-SA 4.0.",
  "keywords": [
    "secret-hitler",
    "board-game",
    "social-deduction",
    "party-game",
    "pass-and-play",
    "expo",
    "react-native"
  ],
  "license": "CC-BY-NC-SA-4.0",
  "author": "Anuj Pratap Singh <anujjadon98@gmail.com>",
  "homepage": "https://github.com/contactanuj/secret-hitler-passandplay#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/contactanuj/secret-hitler-passandplay.git"
  },
  "bugs": {
    "url": "https://github.com/contactanuj/secret-hitler-passandplay/issues"
  },
  "engines": {
    "node": ">=18 <21"
  },
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "build:html": "node build.js",
    "icon": "node tools/make-icon.js",
    "test": "node tests/engine.test.js && node tests/ui.smoke.test.js",
    "start": "npm run build:html && expo start",
    "android": "npm run build:html && expo run:android",
    "ios": "npm run build:html && expo run:ios",
    "build:android": "npm run build:html && npx eas-cli build -p android --profile preview"
  },
  "dependencies": {
    "expo": "~56.0.11",
    "expo-asset": "~10.0.10",
    "expo-file-system": "~17.0.1",
    "expo-status-bar": "~1.12.1",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-webview": "13.8.6"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0"
  }
}
